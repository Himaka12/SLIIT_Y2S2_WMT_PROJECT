PORT=8080
APP_TIME_ZONE=Asia/Colombo
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/vehicle-app
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRATION_MS=86400000

